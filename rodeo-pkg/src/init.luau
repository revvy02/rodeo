-- rodeo — typed standard library for Roblox Studio scripts
-- Pure DX facade: reads APIs from _G.__rodeo_procs (populated by the runner)
-- Types are generated from runtime.proto via protoc-gen-luau
--
-- Usage:
--   local rodeo = require("@rodeo")  -- typed access to fs, io, process, stream
--   local fs = require("@rodeo/fs")  -- typed sub-module access

-- Proto-generated types (source of truth: runtime.proto)
-- rodeo-pkg sits at packages.rodeo in the rojo tree
-- shared sits at shared in the rojo tree (sibling to packages)
-- proto types are in shared/proto/ (generated by rodeo-shared/build.luau)
local runtime = require(script.Parent.Parent.Parent.shared.proto.runtime)

-- Stream handle (opaque, used by stream.read/write/close and fs.open)
export type StreamHandle = {
	__handle: string,
}

-- Process handle (opaque, returned by process.create)
export type ProcessHandle = {
	__rodeo_pid: string,
	stdin: StreamHandle?,
	stdout: StreamHandle?,
	stderr: StreamHandle?,
}

-- User-facing types (factories unwrap proto wire format)
export type FileMetadata = runtime.FsStatResponse
export type DirectoryEntry = runtime.FsDirEntry

export type Fs = {
	open: (path: string, mode: string?) -> StreamHandle,
	remove: (path: string) -> (),
	stat: (path: string) -> FileMetadata,
	type: (path: string) -> string,
	mkdir: (path: string) -> (),
	exists: (path: string) -> boolean,
	copy: (src: string, dest: string) -> (),
	listdir: (path: string) -> { DirectoryEntry },
	rmdir: (path: string) -> (),
}

export type Io = {
	stdin: StreamHandle,
	stdout: StreamHandle,
	stderr: StreamHandle,
	read: () -> string,
}

export type Stream = {
	read: (handle: StreamHandle) -> string?,
	write: (handle: StreamHandle, data: any) -> (),
	close: (handle: StreamHandle) -> (),
}

export type StdioKind = "default" | "piped" | "inherit" | "none" | "tee"

export type ProcessRunOptions = {
	cwd: string?,
	stdio: StdioKind?,
	stdin: StdioKind?,
	stdout: StdioKind?,
	stderr: StdioKind?,
	env: { [string]: string }?,
}

export type ProcessResult = runtime.ProcessRunResponse

export type Process = {
	args: { string },
	env: { [string]: string? },
	cwd: () -> string,
	homedir: () -> string,
	execpath: () -> string,
	exit: (code: number) -> (),
	run: (argsOrHandle: { string } | ProcessHandle, options: ProcessRunOptions?) -> ProcessResult,
	system: (command: string, options: ProcessRunOptions?) -> ProcessResult,
	create: (args: { string }, options: ProcessRunOptions?) -> ProcessHandle,
	kill: (handle: ProcessHandle) -> (),
}

export type Roblox = {
	load: (path: string) -> { Instance },
	mcp: {
		call: (tool: string, arguments: { [string]: any }?) -> string,
	},
}

export type Rodeo = {
	fs: Fs,
	io: Io,
	process: Process,
	stream: Stream,
	roblox: Roblox,
}

local rodeo = {}

setmetatable(rodeo, {
	__index = function(_, key)
		-- Process-scoped lookup via _G.__rodeo_eid (set by runner)
		local eid = _G.__rodeo_eid
		if eid and _G.__rodeo_procs then
			local g = _G.__rodeo_procs[eid]
			if g then
				return g[key]
			end
		end
		-- Fallback for single-process mode
		local g = _G.__rodeo
		assert(g ~= nil, "rodeo APIs not available — are you running this outside of rodeo?")
		return g[key]
	end,
})

return (rodeo :: any) :: Rodeo
